# Copy to .env and fill in. .env is gitignored.

# FRED API key (free: https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=

# Anthropic API key (for Phase 2 LLM signal layer)
ANTHROPIC_API_KEY=

# Optional: NewsAPI key (Phase 2)
NEWS_API_KEY=

# Optional: Polygon.io key (Phase 2; upgrade from yfinance)
POLYGON_API_KEY=

# Database path (defaults to data/alpha_engine.duckdb if unset)
ALPHA_DB_PATH=

# Log level: DEBUG, INFO, WARNING, ERROR
ALPHA_LOG_LEVEL=INFO
